# Configuration MySQL
MYSQL_ROOT_PASSWORD=votre_mot_de_passe_root
MYSQL_DATABASE=blog_db
MYSQL_USER=admin
MYSQL_PASSWORD=password_admin

# Configuration MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password_mongo

# Configuration API
# Note: On utilise les noms des services définis dans le docker-compose
MONGO_URL=mongodb://admin:password_mongo@db_mongo:27017/blog_db?authSource=admin
MYSQL_HOST=db_mysql